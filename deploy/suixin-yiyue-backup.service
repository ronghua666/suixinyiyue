[Unit]
Description=Suixin Yiyue SQLite backup
Wants=suixin-yiyue.service

[Service]
Type=oneshot
User=suixin
Group=suixin
WorkingDirectory=/opt/suixin-yiyue
EnvironmentFile=-/etc/suixin-yiyue.env
Environment=BACKUP_RETENTION_DAYS=30
Environment=BACKUP_MAX_FILES=30
ExecStart=/opt/suixin-yiyue/venv/bin/python /opt/suixin-yiyue/backend/backup.py
Nice=10
NoNewPrivileges=yes
PrivateTmp=yes
